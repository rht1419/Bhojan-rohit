          "name": "EP-01 Register (GUEST)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_type\": \"GUEST\",\n  \"full_name\": \"Test User\",\n  \"phone\": \"+918971100269\",\n  \"password\": \"Test@1234\"\n}"
            }
          }
        },
        {
          "name": "EP-01 Register (EMPLOYEE)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_type\": \"EMPLOYEE\",\n  \"full_name\": \"Test Employee\",\n  \"phone\": \"+918971100269\",\n  \"password\": \"Test@1234\",\n  \"email\": \"emp001@infosys.com\",\n  \"employee_id\": \"INF-EMP-001\"\n}"
            }
          }
        },
        {
          "name": "EP-02 Verify OTP",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/otp/verify",
