            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"+918971100269\",\n  \"otp\": \"123456\"\n}"
            }
          }
        },
        {
          "name": "EP-03 Login Password",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login/password",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"+918971100269\",\n  \"password\": \"Test@1234\"\n}"
            }
          }
        },
        {
          "name": "EP-04 Refresh Token",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/token/refresh",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
