  expires_at    DateTime
  created_at    DateTime @default(now())
  user          User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([refresh_token])
  @@index([user_id, is_revoked])
  @@map("sessions")
}

model RolePermission {
  id         String    @id @default(uuid())
  role       Role
  module     AppModule
  can_create Boolean   @default(false)
  can_read   Boolean   @default(false)
  can_update Boolean   @default(false)
  can_delete Boolean   @default(false)
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt

  @@unique([role, module])
  @@index([role])
  @@map("role_permissions")
}

model Delegation {
  id           String    @id @default(uuid())
  delegator_id String
  delegatee_id String
  module       AppModule
  reason       String?
  is_active    Boolean   @default(true)
  starts_at    DateTime
  expires_at   DateTime
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  delegatee    User      @relation("delegatee", fields: [delegatee_id], references: [id])
  delegator    User      @relation("delegator", fields: [delegator_id], references: [id])

  @@index([delegatee_id, is_active])
  @@index([expires_at, is_active])
  @@map("delegations")
}

model EmployeeRoster {
  id          String   @id @default(uuid())
  tenant_id   String
  employee_id String
  email       String
  full_name   String
  department  String?
  is_active   Boolean  @default(true)
  uploaded_by String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  uploader    User?    @relation("RosterUploadedBy", fields: [uploaded_by], references: [id])

  @@unique([tenant_id, employee_id])
  @@index([tenant_id, is_active])
  @@index([tenant_id, email])
  @@map("employee_roster")
}

model AuditLog {
  id         String      @id @default(uuid())
  user_id    String?
  tenant_id  String?
  action     AuditAction
  module     AuditModule
  target_id  String?
  device     String?
  old_value  Json?
  new_value  Json?
  ip_address String?
  metadata   Json?
  created_at DateTime    @default(now())
  tenant     Tenant?     @relation(fields: [tenant_id], references: [id])
  user       User?       @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@index([tenant_id])
  @@index([action])
  @@index([module])
  @@index([created_at(sort: Desc)])
  @@index([tenant_id, created_at(sort: Desc)])
  @@map("audit_logs")
}

model BulkUploadLog {
  id            String       @id @default(uuid())
  tenant_id     String
  uploaded_by   String
  file_name     String
  gcs_path      String?
  total_records Int
  success_count Int          @default(0)
  failed_count  Int          @default(0)
  status        UploadStatus @default(PENDING)
  error_details Json?
  created_at    DateTime     @default(now())
  updated_at    DateTime     @updatedAt
  tenant        Tenant       @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  uploader      User         @relation("UploadedBy", fields: [uploaded_by], references: [id])

  @@index([tenant_id, status])
  @@index([uploaded_by])
  @@map("bulk_upload_logs")
}

model VendorSuspensionLog {
  id               String           @id @default(uuid())
  vendor_id        String
  action           SuspensionAction
  reason           String
  actioned_by      String
  created_at       DateTime         @default(now())
  actioned_by_user User             @relation("ActionedSuspensions", fields: [actioned_by], references: [id])
  vendor           User             @relation("VendorSuspensions", fields: [vendor_id], references: [id])

  @@index([vendor_id])
  @@index([actioned_by])
  @@map("vendor_suspension_logs")
}

model AccountDeletionRequest {
  id            String         @id @default(uuid())
